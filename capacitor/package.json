{
  "name": "cryptoedge-pro-app",
  "version": "1.0.0",
  "description": "CryptoEdge Pro - App Nativo",
  "scripts": {
    "build:ios":     "npx cap add ios && npx cap sync && npx cap open ios",
    "build:android": "npx cap add android && npx cap sync && npx cap open android",
    "sync":          "npx cap sync",
    "live":          "npx cap run android --livereload --external"
  },
  "dependencies": {
    "@capacitor/core":          "^5.7.0",
    "@capacitor/cli":           "^5.7.0",
    "@capacitor/android":       "^5.7.0",
    "@capacitor/ios":           "^5.7.0",
    "@capacitor/push-notifications": "^5.1.1",
    "@capacitor/status-bar":    "^5.0.6",
    "@capacitor/splash-screen": "^5.0.7",
    "@capacitor/keyboard":      "^5.0.8",
    "@capacitor/haptics":       "^5.0.7",
    "@capacitor/browser":       "^5.1.3",
    "@capacitor/share":         "^5.0.7"
  }
}
