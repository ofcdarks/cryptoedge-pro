BOT_STRATEGY=hft
BOT_TRADE_MODE=auto
BOT_TESTNET=false
BOT_MARKET=futures
BOT_CAPITAL=100

# ── HFT Precisão Profissional ─────────────────────────────────────────────────
HFT_RISK_PCT=10.0
HFT_TP_PCT=1.00
HFT_SL_PCT=0.50
HFT_DAILY_LOSS=5.0
HFT_COOLDOWN=60
HFT_TIMEFRAME=1m
HFT_MAX_TRADES=3
HFT_MIN_RR=1.8

# ── Filtros de qualidade (menos trades, melhores entradas) ────────────────────
HFT_MIN_SCORE=3.5
HFT_MIN_SIGNALS=3
HFT_RSI_BUY=22
HFT_RSI_SELL=78
HFT_ADX_MIN=18
HFT_CONFIRM_MAX_DRIFT=0.80
HFT_SKIP_CONFIRM=false

# ── Pares (sem BTC/ETH — notional muito alto pra $100) ───────────────────────
HFT_PAIRS=SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,AVAXUSDT,DOTUSDT,MATICUSDT

# ── IA analisa antes de entrar ────────────────────────────────────────────────
HFT_AI_ENABLED=true
HFT_AI_MIN_CONF=0.65

# ── Juros compostos e visibilidade ───────────────────────────────────────────
HFT_COMPOUND=true
HFT_HEARTBEAT_SEC=300
HFT_NOTIFY_SIGNAL=true
HFT_UPDATE_INTERVAL=1800
HFT_ONLY_BUY=false

BOT_SCAN_ENABLED=false
