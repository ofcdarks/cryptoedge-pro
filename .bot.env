# CryptoEdge Pro — Bot config otimizado (10% risk + juros compostos)
BOT_STRATEGY=hft
BOT_TRADE_MODE=auto
BOT_TESTNET=true
BOT_CAPITAL=100

# Parâmetros HFT — otimizados para $100 capital
HFT_RISK_PCT=10.0
HFT_TP_PCT=0.70
HFT_SL_PCT=0.40
HFT_DAILY_LOSS=5.0
HFT_COOLDOWN=30
HFT_TIMEFRAME=1m
HFT_MAX_TRADES=5
HFT_MIN_RR=1.4
HFT_CONFIRM_MAX_DRIFT=0.25

# Juros compostos — capital cresce automaticamente com os lucros
HFT_COMPOUND=true

# IA desativada (latência 3s prejudica HFT 1m)
HFT_AI_ENABLED=false

# Pares
HFT_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,AVAXUSDT,DOTUSDT,MATICUSDT

# Visibilidade — saber que o bot está funcionando
HFT_HEARTBEAT_SEC=300
HFT_NOTIFY_SIGNAL=true
HFT_UPDATE_INTERVAL=1800
