BOT_STRATEGY=hft
BOT_TRADE_MODE=auto
BOT_TESTNET=false
BOT_MARKET=futures
BOT_CAPITAL=229

HFT_RISK_PCT=15.0

# ── Timeframe 15m — filtros rígidos funcionam aqui ───────────────────────────────────────────────────
HFT_TIMEFRAME=15m

# ── TP/SL ajustados para a realidade do ATR no 3m ────────────────────────────
# 15m: ATR real ~0.70% cobre o mínimo exigido de 0.45% com folga
# TP 1.5% exige ATR 0.45% — atingível no 15m, lucro $2.44/win
HFT_TP_PCT=1.50
HFT_SL_PCT=0.50
HFT_DAILY_LOSS=4.0
HFT_MIN_RR=2.0

# ── Filtros de qualidade: INALTERADOS — só entram setups fortes ───────────────
HFT_RSI_BUY=22
HFT_RSI_SELL=78
HFT_ADX_MIN=18
HFT_MIN_SCORE=3.5
HFT_MIN_SIGNALS=3
HFT_MIN_ATR_PCT=0.20

# ── Gestão de posição ────────────────────────────────────────────────────────
HFT_MAX_TRADES=3
HFT_LEVERAGE=5
HFT_FEE_RATE=0.0004
HFT_MIN_NET_PROFIT=0.12
HFT_COOLDOWN=60
HFT_CONFIRM_MAX_DRIFT=0.80
HFT_SKIP_CONFIRM=false

# ── Pares ────────────────────────────────────────────────────────────────────
HFT_PAIRS=SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,AVAXUSDT,DOTUSDT,MATICUSDT

# ── IA e compostos ───────────────────────────────────────────────────────────
HFT_ONLY_BUY=false
HFT_AI_ENABLED=true
HFT_AI_MIN_CONF=0.65
HFT_TRAIL_ENABLED=false
HFT_COMPOUND=true

# ── Notificações ─────────────────────────────────────────────────────────────
HFT_HEARTBEAT_SEC=300
HFT_NOTIFY_SIGNAL=true
HFT_UPDATE_INTERVAL=1800

BOT_SCAN_ENABLED=false