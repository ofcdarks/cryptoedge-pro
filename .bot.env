BOT_STRATEGY=hft
BOT_TRADE_MODE=auto
BOT_TESTNET=false
BOT_MARKET=futures
BOT_CAPITAL=100

# ── HFT Precisão para 3m — calibrado para ATR real 0.15-0.30% ────────────────
# Position $170 (5x) → fee RT $0.17 → TP 0.80% = $1.36 bruto → $1.19 líquido
HFT_RISK_PCT=12.0
HFT_TP_PCT=0.80
HFT_SL_PCT=0.35
HFT_DAILY_LOSS=4.0
HFT_COOLDOWN=45
HFT_TIMEFRAME=3m
HFT_MAX_TRADES=3
HFT_MIN_RR=1.8
HFT_LEVERAGE=5
HFT_FEE_RATE=0.0005

# ── Filtros relaxados (realistas para 3m em ranging) ─────────────────────────
HFT_MIN_SCORE=2.8
HFT_MIN_SIGNALS=3
HFT_RSI_BUY=30
HFT_RSI_SELL=70
HFT_ADX_MIN=12
HFT_MIN_ATR_PCT=0.10
HFT_MIN_NET_PROFIT=0.08
HFT_CONFIRM_MAX_DRIFT=0.40
HFT_SKIP_CONFIRM=false

# ── Ranging: usa RSI_BUY/RSI_SELL em vez de hardcoded 18/82 ─────────────────
HFT_RANGING_RSI_BUY=30
HFT_RANGING_RSI_SELL=70

# ── Pares ────────────────────────────────────────────────────────────────────
HFT_PAIRS=SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,AVAXUSDT,DOTUSDT,MATICUSDT

# ── IA ───────────────────────────────────────────────────────────────────────
HFT_AI_ENABLED=true
HFT_AI_MIN_CONF=0.55

# ── Juros compostos e visibilidade ───────────────────────────────────────────
HFT_COMPOUND=true
HFT_HEARTBEAT_SEC=300
HFT_NOTIFY_SIGNAL=true
HFT_UPDATE_INTERVAL=1800
HFT_ONLY_BUY=false

# ── Trail stop ativo para proteger lucros em 3m ─────────────────────────────
HFT_TRAIL_ENABLED=true
HFT_TRAIL_L1=0.25
HFT_TRAIL_L2=0.40
HFT_TRAIL_L3=0.55
HFT_TRAIL_L4=0.70
HFT_TRAIL_BE_BUF=0.02

BOT_SCAN_ENABLED=false
