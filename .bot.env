BOT_STRATEGY=hft
BOT_TRADE_MODE=auto
BOT_TESTNET=false
BOT_MARKET=futures
BOT_CAPITAL=369

# ── HFT v19 — SIMPLES e TESTADO ─────────────────────────────────────────────
# $369 × 10% = $36.90 budget × 5x = $184.50 position
# Fee RT: $0.18 | SL 0.40% = -$0.74 | Trail ativa BE em +0.12%
HFT_RISK_PCT=10.0
HFT_TP_PCT=1.20
HFT_SL_PCT=0.40
HFT_DAILY_LOSS=3.0

# ── Daily Loss DINAMICO: loss max = lucro do dia anterior ────────────────────
# Nunca perde mais do que ganhou. Ex: ganhou $1.29 ontem → perde max $1.29 hoje
HFT_DYNAMIC_DAILY_LOSS=true
HFT_DAILY_LOSS_FALLBACK_PCT=2.0
HFT_DAILY_LOSS_MIN=0.20

# ── Daily Profit Protector — preserva lucro, sem meta de gain ────────────────
# Ativa quando lucro do dia >= threshold, protege X% do pico
# Se PnL cair abaixo do piso protegido → para no dia com lucro garantido
HFT_DAILY_PROTECT_ENABLED=true
HFT_DAILY_PROTECT_THRESHOLD=0.50
HFT_DAILY_PROTECT_PCT=60
HFT_COOLDOWN=45
HFT_TIMEFRAME=3m
HFT_MAX_TRADES=4
HFT_MIN_RR=1.5
HFT_LEVERAGE=5
HFT_FEE_RATE=0.0005

# ── Filtros relaxados (realistas para 3m em ranging) ─────────────────────────
HFT_MIN_SCORE=2.6
HFT_MIN_SIGNALS=3
HFT_RSI_BUY=30
HFT_RSI_SELL=70
HFT_ADX_MIN=12
HFT_MIN_ATR_PCT=0.10
HFT_MIN_NET_PROFIT=0.08
HFT_CONFIRM_MAX_DRIFT=0.40
HFT_SKIP_CONFIRM=false

# ── Ranging: usa RSI_BUY/RSI_SELL em vez de hardcoded 18/82 ─────────────────
HFT_RANGING_RSI_BUY=30
HFT_RANGING_RSI_SELL=70

# ── Pares: 14 pares diversificados (L1, memes, IA, infra) ───────────────────
HFT_PAIRS=SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,AVAXUSDT,DOTUSDT,MATICUSDT,SUIUSDT,NEARUSDT,1000PEPEUSDT,WIFUSDT,FETUSDT,LINKUSDT

# ── IA ───────────────────────────────────────────────────────────────────────
HFT_AI_ENABLED=true
HFT_AI_MIN_CONF=0.55

# ── Juros compostos e visibilidade ───────────────────────────────────────────
HFT_COMPOUND=true
HFT_HEARTBEAT_SEC=300
HFT_NOTIFY_SIGNAL=true
HFT_UPDATE_INTERVAL=1800
HFT_ONLY_BUY=false

# ── Trail stop 7 fases — ativa MAIS CEDO, trava MAIS lucro ──────────────────
# v18: levels mais próximos + lock % maiores = captura lucro real
HFT_TRAIL_ENABLED=true
HFT_NO_TP_CEILING=true
HFT_TRAIL_L1=0.12
HFT_TRAIL_L2=0.25
HFT_TRAIL_L3=0.40
HFT_TRAIL_L4=0.60
HFT_TRAIL_L5=1.00
HFT_TRAIL_L6=1.50
HFT_TRAIL_BE_BUF=0.03

BOT_SCAN_ENABLED=false

# ══════════════════════════════════════════════════════════════════════════════
# MELHORIAS v17.4
# ══════════════════════════════════════════════════════════════════════════════

# ── MELHORIA 1: Filtro de correlação (max posições na mesma direção) ─────────
HFT_MAX_SAME_DIRECTION=2

# ── MELHORIA 2: Multi-Timeframe (soft filter, não bloqueia) ─────────────────
HFT_MTF_ENABLED=false
HFT_MTF_TIMEFRAME=5m
HFT_MTF_TF_SETUP=15m
HFT_MTF_TF_MACRO=1h

# ── MELHORIA 3: Funding Rate como filtro ─────────────────────────────────────
HFT_FUNDING_ENABLED=true
HFT_FUNDING_WEIGHT=0.5

# ── MELHORIA 6: Blacklist dinâmica agressiva ─────────────────────────────────
HFT_BLACKLIST_CONSEC=3
HFT_BLACKLIST_PAUSE=7200
HFT_BLACKLIST_MIN_WR=35

# ── MELHORIA 8: Alerta de volatilidade extrema ──────────────────────────────
HFT_VOL_PAUSE_PCT=3.0
HFT_VOL_PAUSE_SEC=1800

# ── Slippage Buffer — protege contra diferença preço visto vs executado ───────
HFT_SLIPPAGE_PCT=0.15
HFT_SLIPPAGE_LEARN=true
