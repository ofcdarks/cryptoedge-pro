# ═══════════════════════════════════════════════════════════════════
# BOT — Configuração Geral
# ═══════════════════════════════════════════════════════════════════
BOT_SYMBOL=BTCUSDT
BOT_CAPITAL=300          # USDT total alocado
BOT_STOP_LOSS=0          # Stop global em USDT (0 = desabilitado)
BOT_TESTNET=true         # true = simulação | false = dinheiro real
BOT_TIMEFRAME=15m        # 1m 3m 5m 15m 30m 1h 4h 1d

# ─── Estratégia ativa ─────────────────────────────────────────────
# grid     → Grid Bot: cria ordens em níveis e faz ping-pong
# dca      → Dollar Cost Averaging: compra nas quedas
# scalping → Scalping por RSI: tick a tick, rápido
# trend    → Trend Following: EMA9 x EMA21 no fechamento da vela
# breakout → Rompimento de suporte/resistência com volume
# macd     → MACD crossover de histograma
BOT_STRATEGY=grid

# ─── Grid ─────────────────────────────────────────────────────────
BOT_PRICE_MIN=80000
BOT_PRICE_MAX=90000
BOT_NUM_GRIDS=10

# ─── DCA ──────────────────────────────────────────────────────────
BOT_DCA_DROP=2           # compra a cada X% de queda
BOT_DCA_MAX=5            # máx de ordens DCA abertas

# ─── Scalping (RSI) ───────────────────────────────────────────────
BOT_SCALP_RSI_BUY=30     # RSI abaixo → Long
BOT_SCALP_RSI_SELL=70    # RSI acima  → Short
BOT_SCALP_TP=1.5         # Take Profit %
BOT_SCALP_SL=1.0         # Stop Loss %

# ─── Trend Following (EMA) ────────────────────────────────────────
BOT_TREND_FAST=9         # período EMA rápida
BOT_TREND_SLOW=21        # período EMA lenta
BOT_TREND_SL=2           # Stop Loss %
BOT_TREND_TP=2           # TP = SL × este multiplicador

# ─── Breakout ─────────────────────────────────────────────────────
BOT_BREAK_LOOKBACK=20    # velas para calcular S/R
BOT_BREAK_CONFIRM=0.3    # % de confirmação acima/abaixo do nível
BOT_BREAK_SL=1.5         # Stop Loss %

# ─── MACD ─────────────────────────────────────────────────────────
BOT_MACD_FAST=12
BOT_MACD_SLOW=26
BOT_MACD_SIG=9
BOT_MACD_SL=1.5          # Stop Loss %

# ─── Pattern Engine ───────────────────────────────────────────────────────────
# BOT_STRATEGY=pattern para usar o motor de padrões completo
BOT_MIN_CONF=0.65       # confiança mínima para entrar (0.0–1.0)
BOT_MIN_PATTERNS=1      # mínimo de padrões para confirmar entrada
BOT_REQUIRE_VOL=true    # exige volume acima da média para entrar
BOT_SL_ATR=1.5          # SL = ATR × este multiplicador
BOT_TP_RR=2.0           # TP = SL × este multiplicador (Risk:Reward)
